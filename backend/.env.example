# Copy this file to backend/.env and fill in your values.
# The backend loads backend/.env automatically on startup (via src/config/loadEnv.ts).
# Real environment variables (e.g. from CI/GitHub Actions secrets) always win over this file.

# ── Required for agent API endpoints (/api/agent-tasks, /api/tickets) ─────────
# Without this, every agent endpoint returns 401.
AGENT_API_TOKEN=your-secret-token-here

# ── Shell convenience variable ─────────────────────────────────────────────────
# Used in the curl examples in the docs. Not read by backend code.
APP_BASE_URL=http://localhost:7070

# ── Session security ───────────────────────────────────────────────────────────
# Defaults to an insecure dev value when unset. Set in any deployed environment.
SESSION_SECRET=change-me-in-production

# ── CORS origins ───────────────────────────────────────────────────────────────
# Defaults to http://localhost:7200 when unset. Set in any non-local environment.
CORS_ORIGINS=http://localhost:7200

# ── Production / Turso cloud database ─────────────────────────────────────────
# Leave unset for local SQLite (default). Set both for Turso cloud.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# ── Cron authentication ────────────────────────────────────────────────────────
# Required for Vercel cron triggers (POST /api/cron/...). Not needed locally.
# CRON_SECRET=your-cron-secret
