# Copy this file to backend/.env and fill in your values.
# The backend loads backend/.env automatically on startup (via src/config/loadEnv.ts).
# Real environment variables (e.g. from CI/GitHub Actions secrets) always win over this file.

# Shared secret for all agent API endpoints (/api/agent-tasks, /api/tickets).
# Required. Without it, every agent endpoint returns 401.
AGENT_API_TOKEN=your-secret-token-here

# Base URL of the running backend. Shell convenience variable used in the curl examples in the docs.
# Not read by backend code.
APP_BASE_URL=http://localhost:7070

# Session signing secret. Defaults to an insecure dev value when unset.
# Set this in any deployed environment.
SESSION_SECRET=

# Allowed CORS origins. Defaults to http://localhost:7200 when unset.
# Set this in any non-local environment.
CORS_ORIGINS=http://localhost:7200
