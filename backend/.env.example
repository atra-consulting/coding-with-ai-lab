# Copy this file to backend/.env and fill in your values.
# The backend loads backend/.env automatically on startup (via src/config/loadEnv.ts).
# Real environment variables (e.g. from CI/GitHub Actions secrets) always win over this file.

# Shared secret for all agent API endpoints (/api/agent-tasks, /api/tickets).
# Required. Without it, every agent endpoint returns 401.
AGENT_API_TOKEN=

# Base URL of the running backend. Used in the curl examples in the docs.
APP_BASE_URL=http://localhost:7070
